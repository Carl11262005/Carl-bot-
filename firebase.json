{
  "hosting": {
    "public": "client/dist",
    "ignore": ["firebase.json", "**/.*", "**/node_modules/**"],
    "rewrites": [
      {
        "source": "/api/**",
        "function": "api"
      },
      {
        "source": "**",
        "destination": "/index.html"
      }
    ],
    "predeploy": [
      "npm install --prefix client",
      "npm run build --prefix client"
    ]
  },
  "functions": {
    "source": "server",
    "runtime": "nodejs20",
    "predeploy": [
      "npm install --prefix server"
    ]
  }
}
